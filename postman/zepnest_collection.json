{
  "info": {
    "name": "ZepNest Service Request Application",
    "_postman_id": "e2d4dc4e-5b5f-4c7f-8c3d-7b3f5fbfe001",
    "description": "Collection for testing authentication and service request flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "email",
      "value": "test@example.com"
    },
    {
      "key": "password",
      "value": "Password123!"
    },
    {
      "key": "request_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "url": "{{base_url}}/register",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Test User" },
                { "key": "email", "value": "{{email}}" },
                { "key": "password", "value": "{{password}}" },
                { "key": "confirm_password", "value": "{{password}}" }
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "url": "{{base_url}}/login",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "{{email}}" },
                { "key": "password", "value": "{{password}}" }
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Requests",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/dashboard"
          }
        },
        {
          "name": "Create Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/requests/create",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Leaking pipe", "type": "text" },
                { "key": "description", "value": "Kitchen pipe is leaking and needs repair.", "type": "text" },
                { "key": "category", "value": "Plumbing", "type": "text" },
                { "key": "address", "value": "123 Main Street, Springfield", "type": "text" },
                { "key": "preferred_date", "value": "2026-06-30", "type": "text" },
                { "key": "preferred_time", "value": "10:30", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "View Request Details",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/requests/{{request_id}}"
          }
        },
        {
          "name": "Edit Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/requests/{{request_id}}/edit",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Leaking pipe - updated", "type": "text" },
                { "key": "description", "value": "Updated description for the request.", "type": "text" },
                { "key": "category", "value": "Plumbing", "type": "text" },
                { "key": "address", "value": "123 Main Street, Springfield", "type": "text" },
                { "key": "preferred_date", "value": "2026-07-01", "type": "text" },
                { "key": "preferred_time", "value": "11:00", "type": "text" },
                { "key": "status", "value": "In Progress", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Delete Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/requests/{{request_id}}/delete"
          }
        }
      ]
    }
  ]
}
